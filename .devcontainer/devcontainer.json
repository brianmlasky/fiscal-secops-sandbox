{
  "name": "Fiscal SecOps Sandbox",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/google-cloud-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "hashicorp.terraform"
      ]
    }
  },
  "postCreateCommand": "pip install --user google-genai",
  "remoteUser": "vscode"
}